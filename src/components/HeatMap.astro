---
// A 5×5 residual-risk heat map — the signature visual from the cyber risk
// register artefact, recreated for the web. Illustrative placements.
const likelihoods = [5, 4, 3, 2, 1]; // top → bottom
const impacts = [1, 2, 3, 4, 5]; // left → right

function band(score: number) {
  if (score >= 15) return "critical";
  if (score >= 10) return "high";
  if (score >= 5) return "medium";
  return "low";
}

// Selected residual placements mirroring the register narrative.
const plotted: Record<string, string> = {
  "5-4": "CRR-02", // ransomware, residual 20
  "4-4": "CRR-03", // S3 misconfig
  "3-5": "CRR-04", // PDPA notification
  "3-4": "CRR-01", // privileged access, residual 12
  "2-3": "CRR-09",
  "1-2": "CRR-14",
};
---

<figure class="hm" aria-label="5 by 5 residual risk heat map">
  <div class="hm__grid">
    <span class="hm__axis hm__axis--y">Likelihood →</span>
    {
      likelihoods.map((l) =>
        impacts.map((i) => {
          const score = l * i;
          const key = `${l}-${i}`;
          const id = plotted[key];
          return (
            <div class={`hm__cell hm__cell--${band(score)}`} data-score={score}>
              {id ? <span class="hm__dot">{id}</span> : <span class="hm__score">{score}</span>}
            </div>
          );
        })
      )
    }
    <span class="hm__axis hm__axis--x">Impact →</span>
  </div>
  <figcaption class="hm__legend">
    <span class="risk-badge risk-low">Low</span>
    <span class="risk-badge risk-medium">Medium</span>
    <span class="risk-badge risk-high">High</span>
    <span class="risk-badge risk-critical">Critical</span>
  </figcaption>
</figure>

<style>
  .hm {
    margin: 0;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1rem, 3vw, 1.6rem);
    box-shadow: var(--shadow);
  }
  .hm__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    gap: 5px;
    position: relative;
    aspect-ratio: 1.18 / 1;
  }
  .hm__cell {
    border-radius: 3px;
    display: grid;
    place-items: center;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.78);
    position: relative;
    transition: transform 0.15s ease;
  }
  .hm__cell:hover {
    transform: scale(1.04);
    z-index: 2;
  }
  .hm__cell--low {
    background: var(--risk-low);
  }
  .hm__cell--medium {
    background: var(--risk-medium);
    color: rgba(74, 58, 8, 0.7);
  }
  .hm__cell--high {
    background: var(--risk-high);
  }
  .hm__cell--critical {
    background: var(--risk-critical);
  }
  .hm__score {
    opacity: 0.55;
  }
  .hm__dot {
    font-size: 0.66rem;
    font-weight: 500;
    color: var(--navy);
    background: var(--paper);
    border-radius: 999px;
    padding: 0.22em 0.5em;
    box-shadow: 0 2px 6px rgba(22, 34, 61, 0.3);
    letter-spacing: 0.02em;
  }
  .hm__axis {
    position: absolute;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .hm__axis--x {
    bottom: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
  }
  .hm__axis--y {
    left: -1.5rem;
    top: 50%;
    transform: rotate(-90deg) translateX(50%);
    transform-origin: left center;
    white-space: nowrap;
  }
  .hm__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.9rem;
    justify-content: center;
  }
  .hm__legend .risk-badge {
    font-size: 0.62rem;
  }
</style>

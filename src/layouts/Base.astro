---
import "@fontsource-variable/fraunces";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-sans/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { site, url } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  // Render the footer flush against the last section (no top margin) when that
  // section already provides its own background/spacing — e.g. the homepage CTA.
  footerFlush?: boolean;
}

const { title, description, footerFlush = false } = Astro.props;
const pageTitle = title ? `${title} · ${site.title}` : `${site.name} — ${site.title}`;
const pageDesc = description ?? site.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Content-Security-Policy — production only, so dev HMR/toolbar are unaffected.
        GitHub Pages can't set HTTP headers, so this is delivered via <meta>.
        Note: frame-ancestors / X-Frame-Options are ignored when delivered via
        <meta>; clickjacking protection requires a host that sets real headers. */}
    {import.meta.env.PROD && (
      <meta
        http-equiv="Content-Security-Policy"
        content="default-src 'self'; base-uri 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; object-src 'none'; form-action 'none'; upgrade-insecure-requests"
      />
    )}
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={url("/favicon.svg")} type="image/svg+xml" />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#1f3864" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer flush={footerFlush} />

    {/* Served from a static file (script-src 'self') rather than inlined, so a
        strict CSP needs no per-build hash. is:inline keeps Astro from bundling it. */}
    <script is:inline src={url("/scripts/reveal.js")}></script>

    <style>
      .skip {
        position: absolute;
        left: -999px;
        top: 0.5rem;
        background: var(--navy);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 4px;
        z-index: 100;
        text-decoration: none;
      }
      .skip:focus {
        left: 0.5rem;
      }
    </style>
  </body>
</html>

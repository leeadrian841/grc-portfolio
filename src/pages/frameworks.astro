---
import Base from "../layouts/Base.astro";
import { url } from "../data/site";

type Ref = {
  name: string;
  cite: string;
  cost: "Free" | "Paid" | "Free w/ reg.";
  desc: string;
  link: string;
};

const groups: { title: string; mark: string; refs: Ref[] }[] = [
  {
    title: "Singapore regulations",
    mark: "Mandatory for FSI roles",
    refs: [
      {
        name: "MAS Technology Risk Management Guidelines",
        cite: "MAS TRM §3,6,7,8,9",
        cost: "Free",
        desc: "The single most important document for a GRC role in Singapore's financial sector. Section 9 (IT Outsourcing) is the entire basis of the TPRM project.",
        link: "https://www.mas.gov.sg/regulation/guidelines/technology-risk-management-guidelines",
      },
      {
        name: "MAS Guidelines on Outsourcing (FIs other than Banks)",
        cite: "Outsourcing",
        cost: "Free",
        desc: "The non-bank outsourcing regime — effective 11 Dec 2024 (last revised Jan 2025), replacing the 2018 unified guidelines. Applies to payment-services FIs like PayWave; complements MAS TRM Section 9 on vendor risk.",
        link: "https://www.mas.gov.sg/regulation/guidelines/guidelines-on-outsourcing-financial-institutions-other-than-banks",
      },
      {
        name: "Personal Data Protection Act (PDPA) 2012",
        cite: "PDPA §26B",
        cost: "Free",
        desc: "Singapore's primary data protection law. The 72-hour breach notification obligation drives risk CRR-004. Penalties up to SGD 1M or 10% of turnover.",
        link: "https://sso.agc.gov.sg/Act/PDPA2012",
      },
      {
        name: "Cybersecurity Act 2018 / CSA",
        cite: "CII",
        cost: "Free",
        desc: "Governs Critical Information Infrastructure requirements. Referenced for completeness; CSA also issues SingCERT alerts and advisories.",
        link: "https://www.csa.gov.sg",
      },
    ],
  },
  {
    title: "International standards — ISO/IEC",
    mark: "ISMS & risk",
    refs: [
      {
        name: "ISO/IEC 27001:2022",
        cite: "Clauses 4–10 + Annex A",
        cost: "Paid",
        desc: "The standard the gap analysis is built on. 93 controls across four themes plus the mandatory management-system clauses most candidates skip.",
        link: "https://www.iso.org/standard/27001",
      },
      {
        name: "ISO/IEC 27002:2022",
        cite: "Implementation",
        cost: "Paid",
        desc: "Companion implementation guidance for the Annex A controls. 27001 says what; 27002 says how.",
        link: "https://www.iso.org/standard/75652.html",
      },
      {
        name: "ISO/IEC 27005:2022",
        cite: "Risk management",
        cost: "Paid",
        desc: "The information security risk management standard underpinning the register methodology.",
        link: "https://www.iso.org/standard/80585.html",
      },
    ],
  },
  {
    title: "NIST frameworks",
    mark: "All free",
    refs: [
      {
        name: "NIST Cybersecurity Framework (CSF) 2.0",
        cite: "GV·ID·PR·DE·RS·RC",
        cost: "Free",
        desc: "Used throughout the risk register as the functional categorisation that guarantees completeness across six functions.",
        link: "https://www.nist.gov/cyberframework",
      },
      {
        name: "NIST SP 800-30 Rev 1",
        cite: "Risk assessment",
        cost: "Free",
        desc: "The risk assessment methodology bible. Threat source / threat event / vulnerability / likelihood / impact — the four-part decomposition used per risk.",
        link: "https://csrc.nist.gov/pubs/sp/800/30/r1/final",
      },
      {
        name: "NIST IR 8286",
        cite: "Cyber → ERM",
        cost: "Free",
        desc: "Bridges cyber risk and enterprise risk management — the board-communication framework behind the executive summary deliverable.",
        link: "https://nvlpubs.nist.gov/nistpubs/ir/2020/NIST.IR.8286.pdf",
      },
      {
        name: "NIST SP 800-61 Rev 2",
        cite: "Incident response",
        cost: "Free",
        desc: "The incident-handling lifecycle behind the Incident Response policy (POL-004): preparation, detection & analysis, containment, eradication & recovery, and post-incident activity.",
        link: "https://csrc.nist.gov/pubs/sp/800/61/r2/final",
      },
    ],
  },
  {
    title: "Industry & threat intelligence",
    mark: "Free",
    refs: [
      {
        name: "PCI DSS v4.0",
        cite: "Req 3,4,6,7,8,10",
        cost: "Free w/ reg.",
        desc: "Mandatory for processing cardholder data. Cited extensively because PayWave is a payments fintech — encryption, MFA, logging, secure SDLC.",
        link: "https://www.pcisecuritystandards.org/document_library/",
      },
      {
        name: "MITRE ATT&CK",
        cite: "Threat actions",
        cost: "Free",
        desc: "Adversary tactics and techniques knowledge base, cross-referenced during threat identification so threat actions are realistic and current.",
        link: "https://attack.mitre.org",
      },
      {
        name: "OWASP Top 10",
        cite: "Secure SDLC",
        cost: "Free",
        desc: "Critical web application risks — context for the secure development controls and the insecure-code risk in the register.",
        link: "https://owasp.org/www-project-top-ten/",
      },
    ],
  },
];

const mapping = [
  ["ISO 27001 Gap Analysis", "ISO 27001:2022", "Clauses 4–10 + Annex A"],
  ["Statement of Applicability", "ISO 27001", "Clause 6.1.3(d) — mandatory"],
  ["Remediation Roadmap", "ISO 27001", "Clause 6.1.3(e) + 8.3"],
  ["Risk Register methodology", "ISO 27005 + NIST SP 800-30", "L×I scoring approach"],
  ["Risk function mapping", "NIST CSF 2.0", "Six functions"],
  ["Threat identification", "MITRE ATT&CK", "Adversary techniques"],
  ["Treatment decisions", "ISO 31000:2018", "Mitigate/Accept/Transfer/Avoid"],
  ["TPRM Policy", "MAS TRM + Outsourcing", "Section 9"],
  ["TPRM tiering", "ISO 27001", "A.5.19–A.5.22"],
  ["Executive summary", "NIST IR 8286", "Cyber → enterprise risk"],
  ["Policy library register", "ISO 27001 + MAS TRM", "A.5.1 + §3 governance"],
  ["Access Control policy", "ISO 27001 + PCI DSS", "A.5.15–A.8.5; Req 7,8"],
  ["Incident Response policy", "NIST SP 800-61 + PDPA", "Lifecycle + §26A–D"],
  ["Cryptography policy", "ISO 27001 + NIST", "A.8.24; FIPS 140-3, SP 800-57"],
];
---

<Base
  title="Framework Reference"
  description="The regulatory frameworks, international standards and industry guidelines underpinning the PayWave portfolio — with official source links."
>
  <header class="fhead">
    <div class="wrap">
      <span class="section-mark">Reference</span>
      <h1>Frameworks behind the work.</h1>
      <p class="fhead__lead">
        Every artefact in this portfolio is anchored to a specific clause, section
        or paragraph in an authoritative source. When a hiring manager asks "why
        did you do it that way?", the answer is a citation — not an opinion. Here
        are the source documents, with official links.
      </p>
    </div>
  </header>

  <div class="wrap fbody">
    {
      groups.map((g) => (
        <section class="fgroup reveal">
          <div class="fgroup__head">
            <h2>{g.title}</h2>
            <span class="section-mark">{g.mark}</span>
          </div>
          <div class="fgrid">
            {g.refs.map((r) => (
              <a class="fref" href={r.link} target="_blank" rel="noopener noreferrer">
                <div class="fref__top">
                  <span class="cite">{r.cite}</span>
                  <span class={`fref__cost fref__cost--${r.cost === "Free" ? "free" : "paid"}`}>
                    {r.cost}
                  </span>
                </div>
                <h3 class="fref__name">{r.name}</h3>
                <p class="fref__desc">{r.desc}</p>
                <span class="fref__link">
                  Official source
                  <svg viewBox="0 0 24 24" fill="none"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </a>
            ))}
          </div>
        </section>
      ))
    }

    <section class="fgroup reveal">
      <div class="fgroup__head">
        <h2>Artefact → framework mapping</h2>
        <span class="section-mark">Interview-ready</span>
      </div>
      <div class="ftable-wrap">
        <table class="ftable">
          <thead>
            <tr>
              <th>Artefact</th>
              <th>Primary framework</th>
              <th>Specific reference</th>
            </tr>
          </thead>
          <tbody>
            {mapping.map((row) => (
              <tr>
                <td>{row[0]}</td>
                <td>{row[1]}</td>
                <td><span class="cite">{row[2]}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="fnote">
        Framework versions, URLs and pricing change over time — always verify
        currency on the official source before quoting in interviews or production
        work. The Singapore-specific frameworks (MAS, PDPC) are particularly
        active.
      </p>
    </section>

    <div class="fback reveal">
      <a class="btn btn-ghost" href={url("/#projects")}>← Back to the projects</a>
    </div>
  </div>
</Base>

<style>
  .fhead {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--navy) 5%, var(--paper));
  }
  .fhead h1 {
    margin-top: 0.9rem;
    max-width: 18ch;
  }
  .fhead__lead {
    margin-top: 1.3rem;
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 62ch;
  }
  .fbody {
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .fgroup {
    margin-bottom: clamp(2.8rem, 5vw, 4rem);
  }
  .fgroup__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }
  .fgrid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.1rem;
  }
  .fref {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.3rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--ink);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .fref:hover {
    transform: translateY(-3px);
    border-color: var(--navy);
    box-shadow: var(--shadow-lift);
  }
  .fref__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .fref__cost {
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2em 0.5em;
    border-radius: 3px;
  }
  .fref__cost--free {
    color: var(--risk-low);
    background: color-mix(in srgb, var(--risk-low) 14%, transparent);
  }
  .fref__cost--paid {
    color: var(--brass-deep);
    background: color-mix(in srgb, var(--brass) 14%, transparent);
  }
  .fref__name {
    font-size: 1.12rem;
    line-height: 1.2;
  }
  .fref__desc {
    font-size: 0.84rem;
    color: var(--ink-soft);
    line-height: 1.55;
    flex: 1;
  }
  .fref__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--navy);
  }
  .fref__link svg {
    width: 0.95em;
    height: 0.95em;
    color: var(--brass);
  }

  /* table */
  .ftable-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--card);
  }
  .ftable {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
  }
  .ftable th {
    text-align: left;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--navy);
    padding: 0.85rem 1.1rem;
    font-weight: 500;
  }
  .ftable td {
    padding: 0.8rem 1.1rem;
    border-top: 1px solid var(--line);
    font-size: 0.88rem;
    color: var(--ink-soft);
    vertical-align: middle;
  }
  .ftable td:first-child {
    color: var(--navy);
    font-weight: 600;
  }
  .ftable tbody tr:hover {
    background: color-mix(in srgb, var(--navy) 3%, transparent);
  }
  .fnote {
    margin-top: 1.2rem;
    font-size: 0.78rem;
    color: var(--ink-mute);
    font-style: italic;
    line-height: 1.55;
    max-width: 70ch;
  }
  .fback {
    margin-top: 2.5rem;
  }
</style>

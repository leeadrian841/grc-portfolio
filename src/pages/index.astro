---
import Base from "../layouts/Base.astro";
import HeatMap from "../components/HeatMap.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site, url } from "../data/site";

const facts = [
  { k: "Industry", v: "Financial technology — digital payments" },
  { k: "Headquarters", v: "Singapore · One-North Business Park" },
  { k: "Scale", v: "~120 staff · 80 engineering, 40 corporate" },
  { k: "Platform", v: "Payments engine, mobile app, merchant portal" },
  { k: "Cloud", v: "AWS — Singapore primary, Tokyo DR" },
  { k: "Regulatory", v: "MAS TRM · MAS Outsourcing · PDPA · PCI DSS" },
];

const icons: Record<string, string> = {
  github: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  email: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/></svg>`,
};

const contacts = [
  site.github ? { label: "GitHub", href: site.github, icon: "github", external: true } : null,
  site.linkedin ? { label: "LinkedIn", href: site.linkedin, icon: "linkedin", external: true } : null,
  site.email ? { label: "Email", href: `mailto:${site.email}`, icon: "email", external: false } : null,
].filter(Boolean) as { label: string; href: string; icon: string; external: boolean }[];
---

<Base>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="wrap hero__inner">
      <div class="hero__text">
        <p class="eyebrow reveal">GRC Portfolio · Singapore Financial Services</p>
        <h1 class="hero__title reveal">
          Governance, risk &amp; compliance built as <em>evidence</em>, not theory.
        </h1>
        <p class="hero__lead reveal">
          I'm moving from IT project engineering into a GRC analyst role in
          cybersecurity. Rather than certificates alone, this is the working
          proof: three integrated artefacts built around one fictional Singapore
          fintech, each anchored to a specific regulatory clause.
        </p>
        <div class="hero__cta reveal">
          <a class="btn btn-primary" href="#projects">
            View the projects
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a class="btn btn-ghost" href={url("/frameworks")}>Frameworks</a>
        </div>
        <dl class="hero__stats reveal">
          <div><dt>4</dt><dd>Completed projects</dd></div>
          <div><dt>15</dt><dd>Downloadable artefacts</dd></div>
          <div><dt>1</dt><dd>Continuous ISMS</dd></div>
        </dl>
      </div>

      <aside class="hero__aside reveal" aria-label="Residual risk heat map preview">
        <div class="hero__asideHead">
          <span class="section-mark">Risk register · residual</span>
        </div>
        <HeatMap />
        <p class="hero__asideNote">
          The 5×5 matrix from Project 02 — likelihood against four-dimension
          impact, plotting residual scores after existing controls.
        </p>
      </aside>
    </div>
  </section>

  <!-- ========================== SCENARIO ========================== -->
  <section id="scenario" class="sec">
    <div class="wrap">
      <div class="sec__head reveal">
        <span class="section-mark">The scenario</span>
        <h2>One fictional company, deliberately chosen.</h2>
      </div>
      <div class="scenario">
        <div class="scenario__copy stack reveal">
          <p>
            <strong>PayWave Solutions Pte. Ltd.</strong> is a fictional Singapore fintech I built for this portfolio. Real GRC work happens behind NDAs, so the options were limited: pull from public templates (proves nothing) or build artefacts against a realistic entity. I picked a payments platform on purpose. Payments in Singapore sit under MAS TRM Guidelines, PDPA, and PCI DSS at the same time, so every artefact has to address actual obligations instead of generic global checklists.
          </p>
          <p>
            Each project reuses the same scenario. The gap analysis surfaces weaknesses against ISO 27001:2022. The risk register puts numbers on what those weaknesses cost across the NIST CSF functions. The TPRM framework handles the supplier side under MAS TRM Section 9. The policy library writes the rules behind the controls. Read in order, the four artefacts work as one continuous information security management system, not four standalone deliverables.
          </p>
          <div class="cite-row">
            <span class="cite">MAS TRM</span>
            <span class="cite">MAS Outsourcing</span>
            <span class="cite">PDPA §26B</span>
            <span class="cite">PCI DSS</span>
            <span class="cite">ISO 27001:2022</span>
          </div>
        </div>
        <aside class="spec reveal" aria-label="Company profile">
          <div class="spec__top">
            <span class="spec__tag">Fictional · for demonstration</span>
            <h3 class="spec__name">PayWave Solutions</h3>
            <span class="spec__sub">Pte. Ltd. — digital payments</span>
          </div>
          <dl class="spec__list">
            {facts.map((f) => (
              <div class="spec__row">
                <dt>{f.k}</dt>
                <dd>{f.v}</dd>
              </div>
            ))}
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <!-- ========================== PROJECTS ========================== -->
  <section id="projects" class="sec sec--alt">
    <div class="wrap">
      <div class="sec__head reveal">
        <span class="section-mark">The work · four lenses</span>
        <h2>Compliance, threat, supplier &amp; governance.</h2>
        <p class="sec__intro">
          Four completed projects on the same company, each covering a different lens of GRC. Two more in progress. The findings carry between them. A gap in the analysis becomes a risk in the register, then a treatment action, then a documented control in the policy library.
        </p>
      </div>
      <div class="pgrid">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <!-- ======================== INTEGRATION ========================= -->
  <section class="sec">
    <div class="wrap">
      <blockquote class="pull reveal">
        <p>
          What a hiring manager should see across these projects is not a stack
          of templates — it's <em>one way of thinking</em>. The Singapore
          regulatory overlay is deliberate. The cross-referencing is deliberate.
          Every artefact is anchored to a clause I can cite on demand.
        </p>
      </blockquote>
      <div class="flow reveal" aria-label="How the projects connect">
        <div class="flow__step">
          <span class="flow__lbl risk-badge risk-high">Gap</span>
          <p>A weakness under ISO 27001 Clause 6.1.3</p>
        </div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step">
          <span class="flow__lbl risk-badge risk-critical">Risk</span>
          <p>Becomes a scored vulnerability in the register</p>
        </div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step">
          <span class="flow__lbl risk-badge risk-medium">Treatment</span>
          <p>Becomes a funded action with an owner</p>
        </div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step">
          <span class="flow__lbl risk-badge risk-low">Roadmap</span>
          <p>Becomes a milestone on the remediation plan</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================== CONTACT =========================== -->
  <section id="contact" class="sec sec--cta">
    <div class="wrap cta">
      <div class="cta__text reveal">
        <span class="section-mark">Contact</span>
        <h2>Let's talk about the work.</h2>
        <p>
          I'm targeting GRC analyst roles with Singapore FSIs, Big&nbsp;4 firms and
          MNCs. Happy to walk through any artefact — including the methodology
          behind any single risk score — in an interview.
        </p>
      </div>
      <div class="cta__icons reveal">
        {contacts.map((c) => (
          <a
            class="cta__icon"
            href={c.href}
            aria-label={c.label}
            title={c.label}
            target={c.external ? "_blank" : undefined}
            rel={c.external ? "noopener noreferrer" : undefined}
          >
            <Fragment set:html={icons[c.icon]} />
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    padding-block: clamp(3rem, 7vw, 6rem) clamp(2.5rem, 6vw, 5rem);
    position: relative;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .hero__title {
    font-size: var(--step-5);
    margin-top: 1rem;
    font-variation-settings: "opsz" 144, "wght" 480, "SOFT" 0;
  }
  .hero__title em {
    font-style: italic;
    color: var(--brass-deep);
    font-variation-settings: "opsz" 144, "wght" 480, "SOFT" 30;
  }
  .hero__lead {
    margin-top: 1.6rem;
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 56ch;
  }
  .hero__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
  .hero__stats {
    margin-top: 2.6rem;
    display: flex;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }
  .hero__stats dt {
    font-family: var(--display);
    font-size: 2.2rem;
    color: var(--navy);
    line-height: 1;
  }
  .hero__stats dd {
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin-top: 0.35rem;
    letter-spacing: 0.02em;
  }
  .hero__aside {
    align-self: stretch;
  }
  .hero__asideHead {
    margin-bottom: 0.9rem;
  }
  .hero__asideNote {
    font-size: 0.78rem;
    color: var(--ink-mute);
    line-height: 1.5;
    margin-top: 1rem;
    max-width: 42ch;
  }

  /* ---- generic section ---- */
  .sec {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .sec--alt {
    background: color-mix(in srgb, var(--navy) 4%, transparent);
    border-block: 1px solid var(--line);
  }
  .sec__head {
    max-width: 60ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .sec__head h2 {
    margin-top: 0.9rem;
  }
  .sec__intro {
    margin-top: 1rem;
    color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.55;
  }

  /* ---- scenario ---- */
  .scenario {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
  .scenario__copy p {
    font-size: 1.05rem;
    color: var(--ink-soft);
  }
  .scenario__copy .cite-row {
    margin-top: 1.6rem;
  }
  .spec {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .spec__top {
    background: var(--navy);
    color: var(--paper);
    padding: 1.4rem 1.5rem;
  }
  .spec__tag {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--paper) 70%, var(--blue));
  }
  .spec__name {
    color: #fff;
    font-size: 1.5rem;
    margin-top: 0.5rem;
  }
  .spec__sub {
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--paper) 75%, transparent);
  }
  .spec__list {
    margin: 0;
  }
  .spec__row {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 1rem;
    padding: 0.85rem 1.5rem;
    border-top: 1px solid var(--line);
  }
  .spec__row dt {
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    padding-top: 0.15rem;
  }
  .spec__row dd {
    margin: 0;
    font-size: 0.86rem;
    color: var(--ink);
    line-height: 1.4;
  }

  /* ---- projects grid ---- */
  .pgrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }

  /* ---- pull quote ---- */
  .pull {
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
    max-width: min(94%, 62rem);
    border: 0;
  }
  .pull p {
    font-family: var(--display);
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--navy);
    text-align: center;
    max-width: 48ch;
    margin-inline: auto;
    text-wrap: balance;
  }
  .pull em {
    font-style: italic;
    color: var(--brass-deep);
  }

  /* ---- flow ---- */
  .flow {
    display: flex;
    align-items: stretch;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .flow__step {
    flex: 1 1 180px;
    max-width: 240px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.1rem;
    box-shadow: var(--shadow);
  }
  .flow__step p {
    margin-top: 0.7rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }
  .flow__arrow {
    align-self: center;
    color: var(--line-strong);
    font-size: 1.4rem;
  }

  /* ---- cta ---- */
  .sec--cta {
    background: color-mix(in srgb, var(--navy) 4%, transparent);
    border-top: 1px solid var(--line);
  }
  .cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .cta__text h2 {
    margin-top: 0.8rem;
  }
  .cta__text p {
    margin-top: 1rem;
    color: var(--ink-soft);
    font-size: 1.05rem;
    max-width: 48ch;
  }
  .cta__icons {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .cta__icon {
    display: grid;
    place-items: center;
    padding: 0.2rem;
    color: var(--navy);
    transition: transform 0.18s ease, color 0.18s ease;
  }
  .cta__icon:hover {
    color: var(--brass-deep);
    transform: translateY(-3px);
  }
  .cta__icon :global(svg) {
    width: 2.1rem;
    height: 2.1rem;
    display: block;
  }

  /* ---- responsive ---- */
  @media (max-width: 940px) {
    .hero__inner,
    .scenario,
    .cta {
      grid-template-columns: 1fr;
    }
    .hero__aside {
      max-width: 460px;
    }
    .pgrid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 680px) {
    .flow__arrow {
      transform: rotate(90deg);
      width: 100%;
      text-align: center;
    }
    .flow__step {
      max-width: none;
    }
  }
</style>
